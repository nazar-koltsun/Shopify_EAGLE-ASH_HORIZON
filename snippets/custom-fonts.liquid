{% comment %}
  Self-hosted custom fonts.

  @font-face must live in a .liquid file (not a static .css asset) so that the
  asset_url filter resolves to the hashed Shopify CDN path. Liquid does not run
  inside base.css, which is why the relative/asset_url paths there did not work.
{% endcomment %}
{{ 'Lora-Regular.woff2' | asset_url | preload_tag: as: 'font' }}
{{ 'Lora-SemiBold.woff2' | asset_url | preload_tag: as: 'font' }}
{{ 'Assistant-Regular.woff2' | asset_url | preload_tag: as: 'font' }}
{{ 'Roboto-ExtraLight.woff2' | asset_url | preload_tag: as: 'font' }}
{{ 'Roboto-Light.woff2' | asset_url | preload_tag: as: 'font' }}
{% style %}
  @font-face {
    font-family: 'Lora';
    src: url('{{ "Lora-Regular.woff2" | asset_url }}') format('woff2');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: 'Assistant';
    src: url('{{ "Assistant-Regular.woff2" | asset_url }}') format('woff2');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: 'Roboto';
    src: url('{{ "Roboto-ExtraLight.woff2" | asset_url }}') format('woff2');
    font-weight: 200;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: 'Roboto';
    src: url('{{ "Roboto-Light.woff2" | asset_url }}') format('woff2');
    font-weight: 300;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: 'Lora';
    src: url('{{ "Lora-Medium.woff2" | asset_url }}') format('woff2');
    font-weight: 500;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: 'Lora';
    src: url('{{ "Lora-SemiBold.woff2" | asset_url }}') format('woff2');
    font-weight: 600;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: 'Lora';
    src: url('{{ "Lora-Bold.woff2" | asset_url }}') format('woff2');
    font-weight: 700;
    font-style: normal;
    font-display: swap;
  }
{% endstyle %}
