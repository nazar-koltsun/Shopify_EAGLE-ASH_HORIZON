{% doc %}
  @prompt
    Create 4 layer multirow with top header and subheader. Multirows should be replaced under each other.
    
    Section top margin: 20
    Section bottom margin: 20, Each feature should be one row
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-multirow-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin-top: {{ block.settings.section_top_margin }}px;
    margin-bottom: {{ block.settings.section_bottom_margin }}px;
  }

  .ai-multirow-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.header_alignment }};
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-multirow-heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.subheader_spacing }}px 0;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
  }

  .ai-multirow-subheading-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.subheading_color }};
    font-size: {{ block.settings.subheading_size }}px;
  }

  .ai-multirow-layers-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.row_spacing }}px;
  }

  .ai-multirow-row-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: {{ block.settings.image_width }}% 1fr;
    gap: {{ block.settings.content_gap }}px;
    align-items: center;
    padding: {{ block.settings.row_padding }}px;
    background-color: {{ block.settings.row_background }};
    border-radius: {{ block.settings.row_border_radius }}px;
  }

  .ai-multirow-row-{{ ai_gen_id }}.reverse {
    grid-template-columns: 1fr {{ block.settings.image_width }}%;
  }

  .ai-multirow-row-{{ ai_gen_id }}.reverse .ai-multirow-image-{{ ai_gen_id }} {
    order: 2;
  }

  .ai-multirow-row-{{ ai_gen_id }}.reverse .ai-multirow-content-{{ ai_gen_id }} {
    order: 1;
  }

  .ai-multirow-image-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-multirow-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-multirow-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-multirow-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-multirow-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-multirow-title-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.item_title_color }};
    font-size: {{ block.settings.item_title_size }}px;
    font-weight: 600;
  }

  .ai-multirow-text-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.item_text_color }};
    font-size: {{ block.settings.item_text_size }}px;
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ai-multirow-row-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-multirow-row-{{ ai_gen_id }}.reverse {
      grid-template-columns: 1fr;
    }

    .ai-multirow-row-{{ ai_gen_id }}.reverse .ai-multirow-image-{{ ai_gen_id }} {
      order: 1;
    }

    .ai-multirow-row-{{ ai_gen_id }}.reverse .ai-multirow-content-{{ ai_gen_id }} {
      order: 2;
    }
  }
{% endstyle %}

<multirow-block-{{ ai_gen_id }} class="ai-multirow-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank or block.settings.subheading != blank %}
    <div class="ai-multirow-header-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-multirow-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      {% if block.settings.subheading != blank %}
        <div class="ai-multirow-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</div>
      {% endif %}
    </div>
  {% endif %}

  <div class="ai-multirow-layers-{{ ai_gen_id }}">
    {% for row in (1..4) %}
      {% liquid
        assign image_key = 'row_' | append: row | append: '_image'
        assign title_key = 'row_' | append: row | append: '_title'
        assign text_key = 'row_' | append: row | append: '_text'
        assign layout_key = 'row_' | append: row | append: '_layout'
        
        assign row_image = block.settings[image_key]
        assign row_title = block.settings[title_key]
        assign row_text = block.settings[text_key]
        assign row_layout = block.settings[layout_key]
        
        assign reverse_class = ''
        if row_layout == 'image_right'
          assign reverse_class = 'reverse'
        endif
      %}
      
      <div class="ai-multirow-row-{{ ai_gen_id }} {{ reverse_class }}">
        <div class="ai-multirow-image-{{ ai_gen_id }}">
          {% if row_image %}
            <img
              src="{{ row_image | image_url: width: 1200 }}"
              alt="{{ row_image.alt | escape }}"
              loading="lazy"
              width="{{ row_image.width }}"
              height="{{ row_image.height }}"
            >
          {% else %}
            <div class="ai-multirow-image-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
        
        <div class="ai-multirow-content-{{ ai_gen_id }}">
          {% if row_title != blank %}
            <h3 class="ai-multirow-title-{{ ai_gen_id }}">{{ row_title }}</h3>
          {% endif %}
          
          {% if row_text != blank %}
            <div class="ai-multirow-text-{{ ai_gen_id }}">{{ row_text }}</div>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</multirow-block-{{ ai_gen_id }}>

<script>
  (function() {
    class MultirowBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('multirow-block-{{ ai_gen_id }}', MultirowBlock{{ ai_gen_id }});
  })();
</script>

