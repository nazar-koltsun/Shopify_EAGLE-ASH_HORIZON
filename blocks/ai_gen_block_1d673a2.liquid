{% doc %}
  @prompt
    Create 4 layer multirow with top header and subheader.
    
    Section top margin: 20
    Section bottom margin: 20
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-multirow-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin-top: {{ block.settings.section_top_margin }}px;
    margin-bottom: {{ block.settings.section_bottom_margin }}px;
    margin-left: auto;
    margin-right: auto;
  }

  .ai-multirow-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.header_alignment }};
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-multirow-heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.subheader_spacing }}px 0;
    font-size: {{ block.settings.heading_size }}px;
  }

  .ai-multirow-subheading-{{ ai_gen_id }} {
    color: {{ block.settings.subheading_color }};
    margin: 0;
    font-size: {{ block.settings.subheading_size }}px;
  }

  .ai-multirow-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.row_gap }}px {{ block.settings.column_gap }}px;
  }

  .ai-multirow-layer-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.layer_border_radius }}px;
    background-color: {{ block.settings.layer_background }};
    padding: {{ block.settings.layer_padding }}px;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.layer_content_gap }}px;
  }

  .ai-multirow-layer-image-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.image_height }}px;
    object-fit: cover;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-multirow-layer-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.image_height }}px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-multirow-layer-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-multirow-layer-title-{{ ai_gen_id }} {
    color: {{ block.settings.layer_title_color }};
    margin: 0;
    font-size: {{ block.settings.layer_title_size }}px;
    font-weight: 600;
  }

  .ai-multirow-layer-text-{{ ai_gen_id }} {
    color: {{ block.settings.layer_text_color }};
    margin: 0;
    font-size: {{ block.settings.layer_text_size }}px;
    line-height: 1.5;
  }

  .ai-multirow-layer-link-{{ ai_gen_id }} {
    color: {{ block.settings.link_color }};
    text-decoration: underline;
    font-size: {{ block.settings.layer_text_size }}px;
  }

  .ai-multirow-layer-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-multirow-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-multirow-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.7);
    }

    .ai-multirow-subheading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subheading_size }}px * 0.85);
    }

    .ai-multirow-layer-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.layer_title_size }}px * 0.85);
    }
  }
{% endstyle %}

<multirow-block-{{ ai_gen_id }} class="ai-multirow-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank or block.settings.subheading != blank %}
    <div class="ai-multirow-header-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-multirow-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      {% if block.settings.subheading != blank %}
        <div class="ai-multirow-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</div>
      {% endif %}
    </div>
  {% endif %}

  <div class="ai-multirow-grid-{{ ai_gen_id }}">
    {% for i in (1..4) %}
      {% liquid
        assign image_key = 'layer_' | append: i | append: '_image'
        assign title_key = 'layer_' | append: i | append: '_title'
        assign text_key = 'layer_' | append: i | append: '_text'
        assign link_text_key = 'layer_' | append: i | append: '_link_text'
        assign link_url_key = 'layer_' | append: i | append: '_link_url'

        assign layer_image = block.settings[image_key]
        assign layer_title = block.settings[title_key]
        assign layer_text = block.settings[text_key]
        assign layer_link_text = block.settings[link_text_key]
        assign layer_link_url = block.settings[link_url_key]
      %}

      <div class="ai-multirow-layer-{{ ai_gen_id }}">
        {% if layer_image %}
          <img
            src="{{ layer_image | image_url: width: 800 }}"
            alt="{{ layer_image.alt | escape }}"
            loading="lazy"
            width="{{ layer_image.width }}"
            height="{{ layer_image.height }}"
            class="ai-multirow-layer-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-multirow-layer-image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}

        {% if layer_title != blank %}
          <h3 class="ai-multirow-layer-title-{{ ai_gen_id }}">{{ layer_title }}</h3>
        {% endif %}

        {% if layer_text != blank %}
          <div class="ai-multirow-layer-text-{{ ai_gen_id }}">{{ layer_text }}</div>
        {% endif %}

        {% if layer_link_text != blank and layer_link_url != blank %}
          <a href="{{ layer_link_url }}" class="ai-multirow-layer-link-{{ ai_gen_id }}">
            {{ layer_link_text }}
          </a>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</multirow-block-{{ ai_gen_id }}>

<script>
  (function() {
    class MultirowBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('multirow-block-{{ ai_gen_id }}', MultirowBlock{{ ai_gen_id }});
  })();
</script>

