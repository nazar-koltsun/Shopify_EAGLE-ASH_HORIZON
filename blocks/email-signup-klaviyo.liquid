{% liquid
  assign block_settings = block.settings
  capture klaviyo_style
    render 'size-style', settings: block_settings
    render 'spacing-style', settings: block_settings
  endcapture
%}

{% render 'email-signup-klaviyo-form',
  klaviyo_company_id: block_settings.klaviyo_company_id,
  klaviyo_list_id: block_settings.klaviyo_list_id,
  label: block_settings.label,
  custom_source: 'Eagle & Ash password page',
  form_id: block.id,
  shopify_attributes: block.shopify_attributes,
  style: klaviyo_style
%}

{% stylesheet %}
  .email-signup-block {
    color: #000000;
    min-width: fit-content;
    background-color: transparent;

    @media screen and (max-width: 749px) {
      width: 100%;
      min-width: unset;
    }
  }

  .email-signup-klaviyo__form {
    display: flex;
    flex-direction: column;
    gap: 20px;
    font-family: "Lora"
    , serif;
  }

  .email-signup-klaviyo__form-wrap {
    display: flex;
    align-items: flex-start;
    gap: 12px;

    @media screen and (max-width: 710px) {
      flex-direction: column;
    }
  }

  .email-signup-klaviyo__interest {
    border: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--gap-lg);
    color: #000000;
  }

  .email-signup-klaviyo__interest-options {
    display: flex;
    justify-content: space-between;
    gap: var(--gap-2xl);
    width: 100%;
    margin-top: 20px;
    font-size: 18px;

    @media screen and (max-width: 950px) {
      font-size: 16px;
    }

    @media screen and (max-width: 460px) {
      flex-direction: column;
      gap: 10px;
    }
  }

  .email-signup-klaviyo__interest-option {
    display: inline-flex;
    align-items: center;
    gap: var(--gap-xs);
    cursor: pointer;

    & > span {
      opacity: 0.6;
    }
  }

  .email-signup-klaviyo__interest-option input {
    accent-color: var(--color-primary);
    border-color: black;
    border-width: 2px;
    width: 30px;
    height: 30px;

    @media screen and (max-width: 950px) {
      width: 20px;
      height: 20px;
    }
  }

  .email-signup-klaviyo__interest-option:hover input {
    border-color: black;
  }

  .email-signup-klaviyo__input-group {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    background-color: transparent;
  }

  .email-signup-klaviyo__form .email-signup-klaviyo__input {
    min-height: 55px;
    padding: 0 8px;
    font-family: "Lora"
    , serif;
    font-size: 22px;
    font-weight: 400;
    color: #000000;
    background-color: transparent;
    border-radius: 0;
    border-color: black !important;
    border-width: 1px;
    outline: none;

    &::placeholder {
      color: black;
    }

    @media screen and (max-width: 950px) {
      font-size: 18px;
      min-height: 45px;
    }
  }

  .email-signup__fields {
    flex-grow: 1;

    @media screen and (max-width: 710px) {
      width: 100%;
    }
  }

  .email-signup-klaviyo__input.paragraph {
    width: 100%;
    color: var(--color-input-text);
    outline-color: var(--color-input-background);
  }

  .email-signup-klaviyo__button {
    white-space: nowrap;
    padding: 8px 36px;
    min-height: 55px;
    font-family: "Lora"
    , serif;
    font-weight: 400;
    color: var(--ash-amber-orange);
    background-color: var(--deepest-brand-blue);
    border: none;
    font-size: 24px;
    text-transform: uppercase;
    cursor: pointer;
    transition: 0.3s ease;

    
    &:hover {
      background-color: black;
    }
    
    @media screen and (max-width: 950px) {
      font-size: 18px;
      min-height: 45px;
    }

    @media screen and (max-width: 710px) {
      width: 100%;
      margin-top: 28px;
    }
  }

  .email-signup-klaviyo__message {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-left: -6px;

    @media screen and (max-width: 710px) {
      margin-left: 0;
    }
  }
  
  .email-signup-klaviyo__message svg {
      width: 40px;
      height: 40px;

      @media screen and (max-width: 950px) {
        width: 30px;
        height: 30px;
      }
  }

  .email-signup-klaviyo__message-text {
    margin: 0;
  }

  .email-signup-klaviyo__message .icon-success {
    width: 40px;
    height: 40px;

    @media screen and (max-width: 950px) {
      width: 30px;
      height: 30px;
    }
  }

{% endstylesheet %}

{% schema %}
  {
    "name": "t:names.email_signup_klaviyo",
    "settings": [
      {
        "type": "paragraph",
        "content": "t:content.email_signups_adds_customer_data_to_klaviyo"
      },
      {
        "type": "header",
        "content": "t:content.klaviyo_setup"
      },
      {
        "type": "text",
        "id": "klaviyo_company_id",
        "label": "t:settings.klaviyo_company_id",
        "info": "t:info.klaviyo_company_id"
      },
      {
        "type": "text",
        "id": "klaviyo_list_id",
        "label": "t:settings.klaviyo_list_id",
        "info": "t:info.klaviyo_list_id"
      }, {
        "type": "header",
        "content": "t:content.submit_button"
      }, {
        "type": "text",
        "id": "label",
        "label": "t:settings.label",
        "default": "t:text_defaults.sign_up"
      }
    ],
    "presets": [
      {
        "name": "t:names.email_signup_klaviyo",
        "category": "t:categories.forms"
      }
    ]
  }
{% endschema %}