{%- liquid
  assign title = section.settings.title
  assign bg_image = section.settings.background_image
-%}

<div class="contact-banner">
  <div class="contact-banner__media">
    {%- if bg_image != blank -%}
      <img
        class="contact-banner__image"
        src="{{ bg_image | image_url: width: 1600 }}"
        srcset="
          {{ bg_image | image_url: width: 600 }} 600w,
          {{ bg_image | image_url: width: 900 }} 900w,
          {{ bg_image | image_url: width: 1200 }} 1200w,
          {{ bg_image | image_url: width: 1600 }} 1600w,
          {{ bg_image | image_url: width: 2200 }} 2200w,
          {{ bg_image | image_url: width: 3000 }} 3000w
        "
        sizes="100vw"
        width="{{ bg_image.width }}"
        height="{{ bg_image.height }}"
        alt="{{ bg_image.alt | default: title | escape }}"
        loading="{% if section.index == 1 %}eager{% else %}lazy{% endif %}"
        {% if section.index == 1 %}
        fetchpriority="high"
        {% endif %}>
    {%- endif -%}
  </div>

  <div class="contact-banner__inner">
    {%- if title != blank -%}
      <h1 class="contact-banner__title">{{ title | escape }}</h1>
    {%- endif -%}
  </div>
</div>

{% style %}
  .contact-banner {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 380px;
    overflow: hidden;
    background-color: var(--deepest-brand-blue, #07272d);
    isolation: isolate;
  }

  @media screen and (max-width: 1200px) {
    .contact-banner {
      min-height: 300px;
    }
  }

  @media screen and (max-width: 749px) {
    .contact-banner {
      min-height: 240px;
    }
  }

  .contact-banner__media {
    position: absolute;
    inset: 0;
    z-index: var(--layer-lowest, 0);
  }

  .contact-banner__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .contact-banner__inner {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: 1920px;
    margin-inline: auto;
    padding-inline: 40px;
    padding-block: 80px;
    text-align: center;
  }

  @media screen and (max-width: 749px) {
    .contact-banner__inner {
      padding-inline: 20px;
      padding-block: 60px;
    }
  }

  .contact-banner__title {
    margin: 0;
    font-family: 'Lora', serif;
    font-weight: 500;
    font-size: 40px;
    line-height: 1.2;
    color: #ffffff;
  }

  @media screen and (max-width: 749px) {
    .contact-banner__title {
      font-size: 32px;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Contact Banner",
  "class": "section-wrapper section-contact-banner",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Contact Us"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    }
  ],
  "presets": [
    {
      "name": "Contact Banner"
    }
  ]
}
{% endschema %}
