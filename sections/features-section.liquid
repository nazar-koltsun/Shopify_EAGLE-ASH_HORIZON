{%- liquid
  assign heading = section.settings.heading
-%}

<div class="features-section">
  <div class="features-section__inner">
    {%- if heading != blank -%}
      <h2 class="visually-hidden">{{ heading }}</h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <ul class="features-section__list" role="list">
        {%- for block in section.blocks -%}
          <li class="features-section__item" {{ block.shopify_attributes }}>
            <span class="features-section__label">{{ block.settings.text }}</span>
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .features-section {
    width: 100%;
    background-color: var(--deepest-brand-blue);
  }

  .features-section__inner {
    width: 100%;
    max-width: 1920px;
    margin-inline: auto;
    padding-inline: 116px;
    padding-block: 17px;

    @media screen and (max-width: 1200px) {
      padding-inline: 80px;
    }

    @media screen and (max-width: 950px) {
      padding-inline: 40px;
    }
  }

  .features-section__list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    margin: 0;
    padding: 0;
    list-style: none;

    @media screen and (max-width: 949px) {
      gap: 16px;
    }

    @media screen and (max-width: 749px) {
      flex-direction: column;
      gap: 12px;
    }
  }

  .features-section__item {
    display: flex;
    align-items: center;
  }

  .features-section__label {
    font-family: 'Lora', serif;
    font-weight: 500;
    font-size: 16px;
    line-height: 1.4;
    color: white;
  }

  .features-section__item::after {
    content: '';
    margin-inline-start: 8px;
    width: 5px;
    height: 5px;
    background-color: white;
    border-radius: 50%;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Features Section",
  "class": "section-wrapper section-features",
  "tag": "section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (visually hidden)",
      "default": "Product features"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Feature"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Features Section",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "text": "Timeless Design"
          }
        },
        {
          "type": "feature",
          "settings": {
            "text": "Crafted with Purpose"
          }
        },
        {
          "type": "feature",
          "settings": {
            "text": "Lasting Quality"
          }
        },
        {
          "type": "feature",
          "settings": {
            "text": "Made for Gifting"
          }
        }
      ]
    }
  ]
}
{% endschema %}
