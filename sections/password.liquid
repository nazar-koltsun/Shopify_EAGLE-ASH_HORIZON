<div class="password-promo">
  {%- liquid
    assign promo_image = section.settings.promo_image
  -%}

  <div class="password-promo__media">
    {%- if promo_image != blank -%}
      <img
        class="password-promo__image"
        src="{{ promo_image | image_url: width: 1600 }}"
        srcset="
          {{ promo_image | image_url: width: 600 }} 600w,
          {{ promo_image | image_url: width: 900 }} 900w,
          {{ promo_image | image_url: width: 1200 }} 1200w,
          {{ promo_image | image_url: width: 1600 }} 1600w,
          {{ promo_image | image_url: width: 2200 }} 2200w,
          {{ promo_image | image_url: width: 3000 }} 3000w
        "
        sizes="100vw"
        width="{{ promo_image.width }}"
        height="{{ promo_image.height }}"
        alt="{{ promo_image.alt | default: shop.name | escape }}"
        loading="eager"
        fetchpriority="high"
      >
    {%- endif -%}
  </div>

  <div class="password-promo__inner">
    <div
      class="password-promo__content"
    >
      {%- if section.settings.promo_eyebrow != blank -%}
        <p class="password-promo__eyebrow">{{ section.settings.promo_eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.promo_heading != blank -%}
        <h1 class="password-promo__heading">{{ section.settings.promo_heading }}</h1>
      {%- endif -%}

      {%- if section.settings.promo_body != blank -%}
        <div class="password-promo__body">{{ section.settings.promo_body }}</div>
      {%- endif -%}
    </div>
  </div>
</div>

<div class="password-form-content">
  {%- if section.settings.main_heading != blank -%}
    <h2 class="password-main-content__heading">{{ section.settings.main_heading }}</h2>
  {%- endif -%}

  {%- if section.settings.main_body != blank -%}
    <div class="password-main-content__body">{{ section.settings.main_body }}</div>
  {%- endif -%}

  <div class="password-klaviyo-form">
    {% content_for "block", type: "email-signup-klaviyo", id: "password-klaviyo-form" %}
  </div>
</div>

{% stylesheet %}
  .password-promo {
    position: relative;
    display: flex;
    align-items: center;
    width: 100%;
    overflow: hidden;
    font-family: 'Lora', sans-serif;
    font-weight: 400;
    background-color: var(--deepest-brand-blue, #07272d);
    isolation: isolate;
  }

  .password-promo__media {
    position: absolute;
    inset: 0;
    z-index: var(--layer-lowest);
  }

  .password-promo__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .password-promo__inner {
    position: relative;
    width: 100%;
    max-width: 1920px;
    margin-inline: auto;
    padding: 60px 80px 90px;
  }

  .password-promo__content {
    max-width: 680px;
    display: flex;
    flex-direction: column;
    gap: var(--gap-lg);
    color: var(--color-white);
  }

  .password-promo__eyebrow {
    margin: 0;
    font-size: 18px;
    font-weight: 400;
    text-transform: uppercase;
    color: white;

    @media screen and (max-width: 950px) {
      font-size: 16px;
    }
  }

  .password-promo__heading {
    margin: 0;
    font-family: 'Lora', sans-serif;
    font-weight: 400;
    font-size: 72px;
    color: white;
    line-height: 1.2;
  }

  .password-promo__body {
    margin-top: 30px;
    font-size: 20px;
    color: white;

    & strong {
      font-family: 'Lora', sans-serif;
      font-weight: 700;
    }

    @media screen and (max-width: 950px) {
      font-size: 18px;
      margin-top: 16px;
    }
  }

  .password-promo__body > :first-child {
    margin-block-start: 0;
  }

  .password-promo__body > :last-child {
    margin-block-end: 0;
  }

  @media screen and (max-width: 950px) {
    .password-promo__inner {
      padding-block-start: 24px;
      padding-block-end: 32px;
      padding-inline: 20px;
    }

    .password-promo__content {
      max-width: 470px;
    }
  }

	.password-form-content {
		width: 100%;
		max-width: 1030px;
		margin-inline: auto;
    padding: 40px 80px 60px;
		text-align: center;

    @media screen and (max-width: 950px) {
      padding: 0 20px;
      padding-top: 30px;
      padding-bottom: 60px;
    }
	}

  .password-main-content__heading {
    font-size: 36px;
    font-weight: 400;
    margin-block-end: 24px;

    @media screen and (max-width: 950px) {
      font-size: 24px;
      margin-block-end: 16px; 
    }
  }

  .password-main-content__body {
    font-size: 20px;
    font-family: 'Lora', sans-serif;
    font-weight: 400;

    @media screen and (max-width: 950px) {
      font-size: 16px;
    }
  }

  .password-klaviyo-form {
    margin-top: 30px;

    @media screen and (max-width: 950px) {
      margin-top: 20px;
    }
  }

  @media (max-width: 950px) {
    .section-password h1 {
      font-size: 40px !important;
    }
  }

  .password-main-content {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .password-content {
    text-align: center;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.section",
  "class": "section-wrapper section-password",
  "disabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:content.password_promo"
    },
    {
      "type": "image_picker",
      "id": "promo_image",
      "label": "t:settings.image"
    },
    {
      "type": "text",
      "id": "promo_eyebrow",
      "label": "t:settings.eyebrow",
      "default": "Premium golf gifting"
    },
    {
      "type": "inline_richtext",
      "id": "promo_heading",
      "label": "t:settings.heading",
      "default": "Born from Fire. Made to Fly."
    },
    {
      "type": "richtext",
      "id": "promo_body",
      "label": "t:settings.text",
      "default": "<p>Something worth discovering is almost here. Soon you'll experience <strong>Eagle & Ash</strong> — a thoughtfully curated collection of premium golf gifts created for meaningful moments, exceptional craftsmanship and lasting impressions. Join our waiting list and be among the first to discover what's coming.</p>"
    },
    {
      "type": "header",
      "content": "t:content.password_form_content"
    },
    {
      "type": "inline_richtext",
      "id": "main_heading",
      "label": "t:settings.heading",
      "default": "Join Us From the Beginning"
    },
    {
      "type": "richtext",
      "id": "main_body",
      "label": "t:settings.text",
      "default": "<p>Be among the first to discover new collections, behind-the-scenes stories and exclusive launch updates. No noise—just thoughtful updates worth opening.</p>"
    }
  ]
}
{% endschema %}
