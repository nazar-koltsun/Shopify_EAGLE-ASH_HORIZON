{% comment %} Branded password page footer: logo, contact email, and social links {% endcomment %}

<div
  class="password-footer"
  data-testid="password-footer"
>
  <div class="password-footer__inner">
    <div class="password-footer__logo">
      {% liquid
        assign logo = settings.logo
      %}

        <img
          src="{{ logo | image_url: width: 400 }}"
          srcset="{{ logo | image_url: width: 200 }} 200w, {{ logo | image_url: width: 400 }} 400w"
          sizes="140px"
          width="140"
          height="auto"
          alt="{{ logo.alt | default: shop.name | escape }}"
          loading="lazy"
        >
      
    </div>

    {% if section.settings.email != blank %}
      <div class="password-footer__email">
        <a href="mailto:{{ section.settings.email | strip | escape }}">
          {{- section.settings.email | escape -}}
        </a>
      </div>
    {% endif %}

    <ul class="password-footer__social">
      {% for block in section.blocks %}
        {% render 'password-footer-social-item',
          title: block.settings.title,
          link: block.settings.link,
          icon: block.settings.icon,
          image_upload: block.settings.custom_icon,
          shopify_attributes: block.shopify_attributes
        %}
      {% endfor %}
    </ul>
  </div>
</div>

{% stylesheet %}
  .password-footer {
    background-color: var(--deepest-brand-blue);
    color: var(--ash-amber-orange);
    padding: 8px 60px;
  }

  .password-footer__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--gap-md, 16px);
    width: 100%;
    max-width: 100%;
  }

  .password-footer__logo {
    justify-self: start;
  }

  .password-footer__logo a {
    display: inline-flex;
    color: inherit;
    text-decoration: none;
  }

  .password-footer__logo img {
    display: block;
    width: 140px;
    max-width: 100%;
    height: auto;
    margin-top: 10px;
  }

  .password-footer__shop-name {
    font-size: 1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .password-footer__email {
    justify-self: center;
    text-align: center;
  }

  .password-footer__email a {
    color: var(--ash-amber-orange);
    font-family: 'Lora', serif;
    font-size: 20px;
    font-weight: 400;
    letter-spacing: 0.02em;
    text-decoration: none;
    transition: opacity var(--hover-transition-duration, 0.25s) var(--hover-transition-timing, ease-out);

    @media screen and (max-width: 950px) {
      font-size: 18px;
    }
  }

  .password-footer__email a:hover {
    opacity: 0.8;
  }

  .password-footer__social {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: flex-end;
    gap: 16px;
    margin: 0;
    padding: 0;
    list-style: none;
    justify-self: end;
  }

  .password-footer__social a,
  .password-footer__social .password-footer__social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: var(--icon-size-lg, 24px);
    min-height: var(--icon-size-lg, 24px);
    color: var(--ash-amber-orange, #fe5000);
    text-decoration: none;
    transition: opacity var(--hover-transition-duration, 0.25s) var(--hover-transition-timing, ease-out);
  }

  .password-footer__social a:hover {
    opacity: 0.8;
  }

  .password-footer__social-item {
    display: flex;
  }

  .password-footer__social .password-footer__social-link {
    cursor: default;
  }

  .password-footer__social-icon {
    display: block;
    width: 32px;
    height: 32px;
    fill: currentColor;
  }

  .password-footer__social-label {
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  @media screen and (max-width: 950px) {
    .password-footer {
      padding: 24px 20px;
    }

    .password-footer__inner {
      grid-template-columns: 1fr;
      justify-items: center;
      text-align: center;
    }

    .password-footer__logo,
    .password-footer__email,
    .password-footer__social {
      justify-self: center;
    }

    .password-footer__logo img {
      width: 100px;
    }

    .password-footer__social {
      justify-content: center;
    }
  }
{% endstylesheet %}

