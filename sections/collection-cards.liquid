{%- liquid
  assign heading = section.settings.heading
  assign columns = section.settings.columns_desktop
-%}

<div class="collection-cards" style="--cc-columns: {{ columns }};">
  <div class="collection-cards__inner">
    {%- if heading != blank -%}
      <div class="collection-cards__header">
        <h2 class="collection-cards__heading">{{ heading }}</h2>
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <ul
        class="collection-cards__row"
        id="collection-cards-{{ section.id }}"
        role="list">
        {%- for block in section.blocks -%}
          {%- liquid
            assign card_image = block.settings.image
            assign card_title = block.settings.title
            assign card_link = block.settings.link
          -%}
          <li class="collection-cards__item" {{ block.shopify_attributes }}>
            {%- capture card_inner -%}
              <div class="collection-cards__media">
                {%- if card_image != blank -%}
                  <img
                    class="collection-cards__image"
                    src="{{ card_image | image_url: width: 600 }}"
                    srcset="
                      {{ card_image | image_url: width: 300 }} 300w,
                      {{ card_image | image_url: width: 450 }} 450w,
                      {{ card_image | image_url: width: 600 }} 600w,
                      {{ card_image | image_url: width: 900 }} 900w
                    "
                    sizes="(max-width: 749px) 72vw, (max-width: 990px) 40vw, 20vw"
                    width="{{ card_image.width }}"
                    height="{{ card_image.height }}"
                    alt="{{ card_image.alt | escape }}"
                    loading="lazy"
                    draggable="false"
                  >
                {%- else -%}
                  {{ 'collection-1' | placeholder_svg_tag: 'collection-cards__image collection-cards__image--placeholder' }}
                {%- endif -%}

                {%- if card_title != blank -%}
                  <span class="collection-cards__title">{{ card_title }}</span>
                {%- endif -%}
              </div>
            {%- endcapture -%}
            {%- if card_link != blank -%}
              <a class="collection-cards__card" href="{{ card_link }}">
                {{ card_inner }}
              </a>
            {%- else -%}
              <div class="collection-cards__card">
                {{ card_inner }}
              </div>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</div>

<script>
  (function () {
    var row = document.getElementById('collection-cards-{{ section.id }}');
    if (!row || row.dataset.dragScrollInit === 'true') return;
    row.dataset.dragScrollInit = 'true';

    var DRAG_THRESHOLD = 5;
    var isDown = false;
    var didDrag = false;
    var startX = 0;
    var startScrollLeft = 0;

    row.addEventListener('pointerdown', function (event) {
      // Only enable click-drag for mouse; touch/pen scroll natively.
      if (event.pointerType !== 'mouse' || event.button !== 0) return;
      isDown = true;
      didDrag = false;
      startX = event.clientX;
      startScrollLeft = row.scrollLeft;
    });

    row.addEventListener('pointermove', function (event) {
      if (!isDown) return;
      var delta = event.clientX - startX;
      if (!didDrag && Math.abs(delta) < DRAG_THRESHOLD) return;
      if (!didDrag) {
        didDrag = true;
        row.classList.add('is-dragging');
        // Capture so we keep receiving move/up even if pointer leaves the row.
        if (row.setPointerCapture) {
          try { row.setPointerCapture(event.pointerId); } catch (e) {}
        }
      }
      event.preventDefault();
      row.scrollLeft = startScrollLeft - delta;
    });

    function endDrag(event) {
      if (!isDown) return;
      isDown = false;
      if (didDrag) {
        row.classList.remove('is-dragging');
        if (event && event.pointerId != null && row.releasePointerCapture) {
          try { row.releasePointerCapture(event.pointerId); } catch (e) {}
        }
      }
    }

    row.addEventListener('pointerup', endDrag);
    row.addEventListener('pointercancel', endDrag);

    // Suppress the click that follows a drag so card links don't fire.
    row.addEventListener(
      'click',
      function (event) {
        if (didDrag) {
          event.preventDefault();
          event.stopPropagation();
          didDrag = false;
        }
      },
      true
    );

    row.addEventListener('dragstart', function (event) {
      event.preventDefault();
    });
  })();
</script>

{% stylesheet %}
  .section-collection-cards {
    background-color: var(--deepest-brand-blue);
  }

  .collection-cards {
    --cc-gap: 24px;
    width: 100%;
    max-width: 1920px;
    margin-inline: auto;
    padding-block-start: 72px;
    padding-block-end: 90px;
    background-color: var(--deepest-brand-blue);

    @media screen and (max-width: 1200px) {
      --cc-gap: 18px;
      padding-block-start: 60px;
      padding-block-end: 72px;
    }

    @media screen and (max-width: 749px) {
      --cc-gap: 14px;
      padding-block-start: 40px;
      padding-block-end: 48px;
    }
  }

  .collection-cards__inner {
    width: 100%;
    max-width: 1920px;
    margin-inline: auto;
    padding-inline: 40px;

    @media screen and (max-width: 749px) {
      padding-inline: 20px;
    }
  }

  .collection-cards__header {
    margin-block-end: 40px;

    @media screen and (max-width: 990px) {
      margin-block-end: 28px;
    }

    @media screen and (max-width: 749px) {
      margin-block-end: 20px;
    }
  }

  .collection-cards__heading {
    margin: 0;
    font-family: 'Lora'
    , serif;
    font-weight: 500;
    font-size: 48px;
    line-height: 1.3;
    color: white;

    @media screen and (max-width: 1200px) {
      font-size: 40px;
    }

    @media screen and (max-width: 990px) {
      font-size: 34px;
    }

    @media screen and (max-width: 749px) {
      font-size: 28px;
    }
  }

  .collection-cards__row {
    display: flex;
    flex-wrap: nowrap;
    gap: var(--cc-gap);
    margin: 0;
    padding: 0;
    list-style: none;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    cursor: grab;
  }

  .collection-cards__row::-webkit-scrollbar {
    display: none;
  }

  .collection-cards__row.is-dragging {
    cursor: grabbing;
    scroll-behavior: auto;
    scroll-snap-type: none;
    user-select: none;
  }

  .collection-cards__row.is-dragging .collection-cards__card {
    pointer-events: none;
  }

  .collection-cards__item {
    flex: 0 0 auto;
    flex-shrink: 0;
    width: calc((100% -(var(--cc-columns) - 1) * var(--cc-gap)) / var(--cc-columns));
    scroll-snap-align: start;

    @media screen and (max-width: 990px) {
      width: calc((100% - 2 * var(--cc-gap)) / 2.4);
    }

    @media screen and (max-width: 749px) {
      width: 72%;
    }
  }

  .collection-cards__card {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .collection-cards__media {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background-color: rgba(255, 255, 255, 0.06);
  }

  .collection-cards__image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .collection-cards__image--placeholder {
    background-color: rgba(255, 255, 255, 0.08);
    fill: rgba(255, 255, 255, 0.25);
  }

  .collection-cards__card:hover .collection-cards__image,
  .collection-cards__card:focus-visible .collection-cards__image {
    transform: scale(1.04);
  }

  .collection-cards__card:focus-visible {
    outline: 2px solid white;
    outline-offset: 3px;
  }

  .collection-cards__title {
    position: absolute;
    inset-block-end: 16px;
    inset-inline-start: 16px;
    max-width: calc(100% - 32px);
    font-family: 'Roboto'
    , sans-serif;
    font-weight: 500;
    font-size: 15px;
    line-height: 1.3;
    letter-spacing: 0.02em;
    color: white;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.45);

    @media screen and (max-width: 749px) {
      inset-block-end: 12px;
      inset-inline-start: 12px;
      font-size: 14px;
    }
  }
{% endstylesheet %}

{% schema %}
  {
    "name": "Collection Cards",
    "class": "section-wrapper section-collection-cards",
    "tag": "section",
    "max_blocks": 12,
    "settings": [
      {
        "type": "inline_richtext",
        "id": "heading",
        "label": "Heading",
        "default": "Crafted for Every Golfing Moment"
      }, {
        "type": "header",
        "content": "Layout"
      }, {
        "type": "range",
        "id": "columns_desktop",
        "label": "Cards per row (desktop)",
        "min": 2,
        "max": 6,
        "step": 1,
        "default": 5
      }
    ],
    "blocks": [
      {
        "type": "card",
        "name": "Card",
        "settings": [
          {
            "type": "image_picker",
            "id": "image",
            "label": "Image"
          }, {
            "type": "inline_richtext",
            "id": "title",
            "label": "Title",
            "default": "Card title"
          }, {
            "type": "url",
            "id": "link",
            "label": "Link"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Collection Cards",
        "blocks": [
          {
            "type": "card",
            "settings": {
              "title": "Awards"
            }
          },
          {
            "type": "card",
            "settings": {
              "title": "Recovery"
            }
          },
          {
            "type": "card",
            "settings": {
              "title": "Tees"
            }
          },
          {
            "type": "card",
            "settings": {
              "title": "Essentials"
            }
          }, {
            "type": "card",
            "settings": {
              "title": "Leather"
            }
          }
        ]
      }
    ]
  }
{% endschema %}