{%- liquid
  assign heading = section.settings.heading
-%}

<div class="collection-cards">
  <div class="collection-cards__inner">
    {%- if heading != blank -%}
      <div class="collection-cards__header">
        <h2 class="collection-cards__heading">{{ heading }}</h2>
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div
        class="embla collection-cards__embla"
        id="collection-cards-{{ section.id }}"
        role="region"
        aria-roledescription="carousel"
        aria-label="{{ heading | default: 'Collections' | strip_html | escape }}"
      >
        <div class="embla__viewport collection-cards__viewport" data-embla-viewport>
          <div class="embla__container collection-cards__container" role="list">
            {%- for block in section.blocks -%}
              {%- liquid
                assign card_image = block.settings.image
                assign card_title = block.settings.title
                assign card_link = block.settings.link
              -%}
              <div class="embla__slide collection-cards__item" role="listitem" {{ block.shopify_attributes }}>
                {%- capture card_inner -%}
                  <div class="collection-cards__media">
                    {%- if card_image != blank -%}
                      <img
                        class="collection-cards__image"
                        src="{{ card_image | image_url: width: 600 }}"
                        srcset="
                          {{ card_image | image_url: width: 300 }} 300w,
                          {{ card_image | image_url: width: 450 }} 450w,
                          {{ card_image | image_url: width: 600 }} 600w,
                          {{ card_image | image_url: width: 900 }} 900w
                        "
                        sizes="(max-width: 720px) 40vw, (max-width: 1199px) 30vw, 20vw"
                        width="{{ card_image.width }}"
                        height="{{ card_image.height }}"
                        alt="{{ card_image.alt | escape }}"
                        loading="lazy"
                        draggable="false"
                      >
                    {%- else -%}
                      {{ 'collection-1' | placeholder_svg_tag: 'collection-cards__image collection-cards__image--placeholder' }}
                    {%- endif -%}

                    {%- if card_title != blank -%}
                      <span class="collection-cards__title">{{ card_title }}</span>
                    {%- endif -%}
                  </div>
                {%- endcapture -%}
                {%- if card_link != blank -%}
                  <a class="collection-cards__card" href="{{ card_link }}">
                    {{ card_inner }}
                  </a>
                {%- else -%}
                  <div class="collection-cards__card">
                    {{ card_inner }}
                  </div>
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        </div>
      </div>
    {%- endif -%}
  </div>
</div>

<script type="module">
  import EmblaCarousel from '{{ 'embla-carousel.esm.js' | asset_url }}';

  (function () {
    var root = document.getElementById('collection-cards-{{ section.id }}');
    if (!root || root.dataset.emblaInit === 'true') return;

    var viewport = root.querySelector('[data-embla-viewport]');
    if (!viewport) return;

    root.dataset.emblaInit = 'true';

    EmblaCarousel(viewport, {
      loop: false,
      align: 'start',
      dragFree: false,
      containScroll: 'trimSnaps',
    });
  })();
</script>

{% stylesheet %}
  .section-collection-cards {
    background-color: var(--deepest-brand-blue);
  }

  .collection-cards {
    --cc-gap: 14px;
    --cc-per-view: 3.13;
    width: 100%;
    max-width: 1920px;
    margin-inline: auto;
    padding-block-start: 29px;
    padding-block-end: 114px;
    background-color: var(--deepest-brand-blue);


    @media screen and (max-width: 1200px) {
      padding-block-start: 60px;
      padding-block-end: 72px;
    }

    @media screen and (max-width: 749px) {
      padding-block-start: 40px;
      padding-block-end: 48px;
    }
  }

  .collection-cards__inner {
    width: 100%;
    max-width: 1920px;
    margin-inline: auto;
  }

  .collection-cards__header {
    margin-block-end: 50px;

    @media screen and (max-width: 990px) {
      margin-block-end: 28px;
    }

    @media screen and (max-width: 749px) {
      margin-block-end: 20px;
    }
  }

  .collection-cards__heading {
    margin: 0;
    padding-inline: 10px;
    font-family: 'Lora', serif;
    font-weight: 500;
    font-size: 30px;
    line-height: 1.3;
    color: white;

    @media screen and (max-width: 1200px) {
      font-size: 40px;
    }

    @media screen and (max-width: 990px) {
      font-size: 34px;
    }

    @media screen and (max-width: 749px) {
      font-size: 28px;
    }
  }

  /* Embla structural styles */
  .embla {
    position: relative;
  }

  .collection-cards__viewport {
    overflow: hidden;
    /* Keep hover/focus rings from being clipped vertically */
    padding-block: 6px;
    margin-block: -6px;
  }

  .collection-cards__container {
    display: flex;
    flex-wrap: nowrap;
    gap: var(--cc-gap);
    margin: 0;
    padding: 0;
    touch-action: pan-y pinch-zoom;
  }

  .collection-cards__item {
    flex: 0 0 calc((100% - (var(--cc-per-view) - 1) * var(--cc-gap)) / var(--cc-per-view));
    min-width: 0;
  }

  .collection-cards__card {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .collection-cards__media {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 3.743;
    overflow: hidden;
    background-color: rgba(255, 255, 255, 0.06);
  }

  .collection-cards__image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .collection-cards__image--placeholder {
    background-color: var(--blue-spectrum-dark);
    fill: var(--blue-spectrum-light);
  }

  .collection-cards__card:hover .collection-cards__image,
  .collection-cards__card:focus-visible .collection-cards__image {
    transform: scale(1.04);
  }

  .collection-cards__card:focus-visible {
    outline: 2px solid white;
    outline-offset: 3px;
  }

  .collection-cards__title {
    position: absolute;
    inset-block-end: 0;
    inset-inline-start: 14px;
    font-family: 'Roboto', sans-serif;
    font-weight: 300;
    font-size: 24px;
    line-height: 29px;
    color: white;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.45);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Collection Cards",
  "class": "section-wrapper section-collection-cards",
  "tag": "section",
  "max_blocks": 12,
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Crafted for Every Golfing Moment"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "inline_richtext",
          "id": "title",
          "label": "Title",
          "default": "Card title"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Cards",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "title": "Awards"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Recovery"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Tees"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Essentials"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Leather"
          }
        }
      ]
    }
  ]
}
{% endschema %}
