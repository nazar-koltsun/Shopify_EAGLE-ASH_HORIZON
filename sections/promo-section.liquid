{%- liquid
  assign bg_image = section.settings.background_image
-%}

<div class="promo-section">
  <div class="promo-section__media">
    {%- if bg_image != blank -%}
      <img
        class="promo-section__image"
        src="{{ bg_image | image_url: width: 1600 }}"
        srcset="
          {{ bg_image | image_url: width: 600 }} 600w,
          {{ bg_image | image_url: width: 900 }} 900w,
          {{ bg_image | image_url: width: 1200 }} 1200w,
          {{ bg_image | image_url: width: 1600 }} 1600w,
          {{ bg_image | image_url: width: 2200 }} 2200w,
          {{ bg_image | image_url: width: 3000 }} 3000w
        "
        sizes="100vw"
        width="{{ bg_image.width }}"
        height="{{ bg_image.height }}"
        alt="{{ bg_image.alt | default: shop.name | escape }}"
        loading="lazy"
      >
    {%- endif -%}
    <div class="promo-section__overlay"></div>
  </div>

  <div class="promo-section__inner">
    <div class="promo-section__content">
      {%- if section.settings.heading != blank -%}
        <h2 class="promo-section__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <div class="promo-section__description">{{ section.settings.description }}</div>
      {%- endif -%}

      {%- if section.settings.link_label != blank and section.settings.link_url != blank -%}
        <a class="promo-section__link btn btn--white" href="{{ section.settings.link_url }}">
          {{ section.settings.link_label }}
        </a>
      {%- endif -%}
    </div>
  </div>

  <div class="promo-section__accent-bar"></div>
</div>

{% stylesheet %}
  .promo-section {
    position: relative;
    display: flex;
    align-items: center;
    width: 100%;
    overflow: hidden;
    background-color: var(--deepest-brand-blue, #07272d);
    isolation: isolate;
  }

  .promo-section__media {
    position: absolute;
    inset: 0;
    z-index: var(--layer-lowest, 0);
  }

  .promo-section__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .promo-section__overlay {
    position: absolute;
    inset: 0;
  }

  .promo-section__inner {
    position: relative;
    width: 100%;
    max-width: 1920px;
    margin-inline: auto;
    padding-inline: 116px;
    padding-block-start: 240px;
    padding-block-end: 190px;

    @media screen and (max-width: 1200px) {
      padding-inline: 80px;
      padding-block-start: 180px;
      padding-block-end: 140px;
    }

    @media screen and (max-width: 950px) {
      padding-inline: 40px;
      padding-block-start: 120px;
      padding-block-end: 100px;
    }

    @media screen and (max-width: 749px) {
      padding-inline: 20px;
      padding-block-start: 80px;
      padding-block-end: 70px;
    }
  }

  .promo-section__content {
    max-width: 580px;
    display: flex;
    flex-direction: column;
    color: var(--color-white, #ffffff);
  }

  .promo-section__heading {
    margin: 0;
    font-family: 'Lora', serif;
    font-weight: 500;
    font-size: 40px;
    line-height: 1.2;
    color: white;

    @media screen and (max-width: 749px) {
      font-size: 32px;
    }
  }

  .promo-section__description {
    max-width: 365px;
    margin-top: 20px;
    font-family: 'Roboto', sans-serif;
    font-weight: 300;
    font-size: 20px;
    color: white;

    @media screen and (max-width: 749px) {
      font-size: 18px;
    }
  }

  .promo-section__description > :first-child {
    margin-block-start: 0;
  }

  .promo-section__description > :last-child {
    margin-block-end: 0;
  }

  .promo-section__link {
    margin-top: 80px;
    align-self: flex-start;

    @media screen and (max-width: 749px) {
      margin-top: 55px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Promo Section",
  "class": "section-wrapper section-promo",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:settings.heading",
      "default": "Meaningful Golf Gifts, Designed to Be Remembered"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Thoughtfully crafted with exceptional materials and timeless design.</p>"
    },
    {
      "type": "header",
      "content": "Link"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "t:settings.label",
      "default": "Discover Our Story"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Url"
    }
  ],
  "presets": [
    {
      "name": "Promo Section"
    }
  ]
}
{% endschema %}
