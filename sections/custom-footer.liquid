{% liquid
  assign primary_menu = section.settings.primary_menu
  if primary_menu == blank and linklists['footer'] != blank
    assign primary_menu = linklists['footer']
  endif

  assign secondary_menu = section.settings.secondary_menu
  if secondary_menu == blank and linklists['footer-menu-block-two'] != blank
    assign secondary_menu = linklists['footer-menu-block-two']
  endif

  assign footer_logo = section.settings.logo_image
  if footer_logo == blank and settings.logo != blank
    assign footer_logo = settings.logo
  endif
%}

<div class="section-background custom-footer__top-bar"></div>
<footer
  class="section section--page-width custom-footer"
>
  <div class="custom-footer__main">
    <div class="custom-footer__newsletter">
      {% if section.settings.newsletter_heading != blank %}
        <h2 class="custom-footer__newsletter-heading">{{ section.settings.newsletter_heading }}</h2>
      {% endif %}

      <div class="custom-footer__newsletter-form">
        {% form 'customer', class: 'email-signup-klaviyo__form' %}
          <div class="email-signup-klaviyo__form-wrap">
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="email-signup__fields">
              <div class="email-signup-klaviyo__input-group">
                <input
                  class="email-signup-klaviyo__input"
                  type="email"
                  name="contact[email]"
                  placeholder="Enter your email"
                  autocorrect="off"
                  autocapitalize="off"
                  autocomplete="email"
                  required
                >
              </div>
            </div>
            <button class="email-signup-klaviyo__button" type="submit">Subscribe</button>
          </div>
        {% endform %}
      </div>
    </div>

    <div class="custom-footer__brand">
      {% if footer_logo != blank %}
        <img
          class="custom-footer__logo-image"
          src="{{ footer_logo | image_url: width: 500 }}"
          width="{{ footer_logo.width }}"
          height="{{ footer_logo.height }}"
          alt="{{ footer_logo.alt | default: section.settings.logo_alt | default: shop.name | escape }}"
          loading="lazy"
        >
      {% elsif section.settings.brand_text != blank %}
        <p class="custom-footer__brand-text">{{ section.settings.brand_text }}</p>
      {% endif %}
    </div>

    <div class="custom-footer__menus">
      <nav class="custom-footer__menu-column" aria-label="{{ section.settings.primary_menu_label | escape }}">
        {% if primary_menu != blank %}
          <ul class="custom-footer__menu-list" role="list">
            {% for link in primary_menu.links %}
              <li class="custom-footer__menu-item">
                <a href="{{ link.url }}" class="custom-footer__menu-link">
                  {{- link.title -}}
                </a>
              </li>
            {% endfor %}
          </ul>
        {% endif %}
      </nav>

      <nav class="custom-footer__menu-column" aria-label="{{ section.settings.secondary_menu_label | escape }}">
        {% if secondary_menu != blank %}
          <ul class="custom-footer__menu-list" role="list">
            {% for link in secondary_menu.links %}
              <li class="custom-footer__menu-item">
                <a href="{{ link.url }}" class="custom-footer__menu-link">
                  {{- link.title -}}
                </a>
              </li>
            {% endfor %}
          </ul>
        {% endif %}
      </nav>
    </div>
  </div>

  <div class="custom-footer__bottom">
    <div class="custom-footer__meta" aria-label="{{ section.settings.bottom_meta_label | escape }}">
      {% if section.settings.meta_part_one != blank %}
        <span>{{ section.settings.meta_part_one }}</span>
      {% endif %}
      {% if section.settings.meta_part_two != blank %}
        <span>{{ section.settings.meta_part_two }}</span>
      {% endif %}
      {% if section.settings.meta_part_three != blank %}
        <span>{{ section.settings.meta_part_three }}</span>
      {% endif %}
    </div>

    {% if section.settings.contact_email != blank %}
      <a class="custom-footer__email" href="mailto:{{ section.settings.contact_email | strip | escape }}">
        {{- section.settings.contact_email | escape -}}
      </a>
    {% endif %}

    <ul class="custom-footer__social" role="list" aria-label="{{ section.settings.social_label | escape }}">
      {% for block in section.blocks %}
        {% if block.type == 'social_link' %}
          {% render 'password-footer-social-item',
            title: block.settings.title,
            link: block.settings.link,
            image_upload: block.settings.custom_icon,
            shopify_attributes: block.shopify_attributes,
            modifier_class: 'custom-footer__social-item'
          %}
        {% endif %}
      {% endfor %}
    </ul>
  </div>
</footer>

{% stylesheet %}
  .custom-footer-section.shopify-section {
    background-color: #ffffff;
    --color-background: #ffffff;
    --color-foreground: #1f2937;
    --color-foreground-rgb: 31 41 55;
    --color-input-background: #ffffff;
    --color-input-hover-background: #ffffff;
  }

  .custom-footer-section > .section-background.custom-footer__top-bar {
    background-color: #ffffff;
  }

  .custom-footer__top-bar {
    min-height: 24px;
    background-color: #ffffff;
  }

  .custom-footer,
  .custom-footer__main,
  .custom-footer__bottom {
    background-color: #ffffff;
    color: #1f2937;
  }

  .custom-footer {
    padding-top: 26px;
    padding-bottom: 10px;
  }

  .custom-footer :is(a, button, input):focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 2px;
  }

  .custom-footer__main {
    display: grid;
    grid-template-columns: minmax(260px, 1fr) auto minmax(220px, 0.9fr);
    align-items: start;
    column-gap: clamp(18px, 4vw, 56px);
    row-gap: 24px;
  }

  .custom-footer__newsletter {
    display: grid;
    gap: 10px;
    max-width: 460px;
  }

  .custom-footer__newsletter-heading {
    margin: 0;
    font-family: 'Lora', serif;
    font-weight: 400;
    font-size: clamp(22px, 2vw, 35px);
    color: #1f2937;
    line-height: 1.2;
  }

  .custom-footer__newsletter-form .email-signup-klaviyo__form {
    gap: 8px;
  }

  .custom-footer__newsletter-form .email-signup-klaviyo__form-wrap {
    align-items: stretch;
    gap: 0;
  }

  .custom-footer__newsletter-form .email-signup-klaviyo__input-group {
    border-bottom: 1px solid #1f2937;
  }

  .custom-footer__newsletter-form .email-signup-klaviyo__input {
    min-height: 34px;
    border: none !important;
    border-radius: 0;
    padding-inline: 0;
    background-color: #ffffff;
    color: #1f2937;
    font-size: clamp(14px, 1.1vw, 20px);
  }

  .custom-footer__newsletter-form .email-signup-klaviyo__input::placeholder {
    color: #1f2937;
  }

  .custom-footer__newsletter-form .email-signup-klaviyo__button {
    min-height: 34px;
    border: 0;
    padding: 0 0 0 12px;
    background: transparent;
    color: #1f2937;
    font-size: clamp(14px, 1.1vw, 20px);
    line-height: 1;
  }

  .custom-footer__newsletter-form .email-signup-klaviyo__button:hover {
    background: transparent;
    opacity: 0.8;
  }

  .custom-footer__newsletter-form .email-signup__fields {
    min-width: 0;
  }

  .custom-footer__newsletter-form .email-signup-klaviyo__interest-options {
    justify-content: flex-start;
    gap: 20px;
    margin-top: 4px;
    font-size: clamp(11px, 0.85vw, 14px);
  }

  .custom-footer__newsletter-form .email-signup-klaviyo__interest-option input {
    width: 11px;
    height: 11px;
    accent-color: #1f2937;
  }

  .custom-footer__brand {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100%;
  }

  .custom-footer__logo-image {
    display: block;
    width: 100%;
    height: auto;
    max-width: 152px;
  }

  .custom-footer__brand-text {
    margin: 0;
    font-size: clamp(18px, 1.5vw, 30px);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .custom-footer__menus {
    display: grid;
    grid-template-columns: repeat(2, minmax(125px, 1fr));
    gap: 6px 24px;
  }

  .custom-footer__menu-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .custom-footer__menu-item {
    margin: 0;
  }

  .custom-footer__menu-link {
    color: #1f2937;
    font-family: 'Lora', serif;
    font-size: clamp(13px, 1vw, 18px);
    line-height: 1.35;
    text-decoration: none;
  }

  .custom-footer__menu-link:hover {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .custom-footer__bottom {
    margin-top: 12px;
    padding-top: 8px;
    border-top: 1px solid #1f2937;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto auto;
    align-items: center;
    column-gap: 24px;
    row-gap: 8px;
  }

  .custom-footer__meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 14px;
    font-size: clamp(10px, 0.9vw, 13px);
    line-height: 1.35;
  }

  .custom-footer__email {
    color: #1f2937;
    font-size: clamp(12px, 1vw, 15px);
    text-decoration: none;
    white-space: nowrap;
  }

  .custom-footer__email:hover {
    text-decoration: underline;
  }

  .custom-footer__social {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .custom-footer__social .password-footer__social-item {
    display: flex;
  }

  .custom-footer__social .password-footer__social-icon {
    width: 18px;
    height: 18px;
    color: #1f2937;
  }

  .custom-footer__social :is(a, .password-footer__social-link) {
    color: #1f2937;
    text-decoration: none;
  }

  @media screen and (max-width: 989px) {
    .custom-footer__top-bar {
      min-height: 18px;
    }

    .custom-footer__main {
      grid-template-columns: 1fr;
      row-gap: 20px;
    }

    .custom-footer__newsletter {
      max-width: 100%;
    }

    .custom-footer__brand {
      justify-content: flex-start;
    }

    .custom-footer__menus {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .custom-footer__bottom {
      grid-template-columns: 1fr;
      justify-items: flex-start;
    }
  }

  @media screen and (max-width: 749px) {
    .custom-footer {
      padding-inline: 20px;
      padding-top: 20px;
      padding-bottom: 18px;
    }

    .custom-footer__newsletter-form .email-signup-klaviyo__form-wrap {
      flex-direction: row;
    }

    .custom-footer__newsletter-form .email-signup-klaviyo__button {
      width: auto;
      margin-top: 0;
    }

    .custom-footer__newsletter-form .email-signup-klaviyo__interest-options {
      flex-wrap: wrap;
      gap: 8px 16px;
    }

    .custom-footer__menus {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Custom footer",
  "class": "section-wrapper custom-footer-section",
  "tag": "footer",
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Newsletter content"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Heading",
      "default": "Be the first to discover new collections."
    },
    {
      "type": "header",
      "content": "Brand content"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo image"
    },
    {
      "type": "text",
      "id": "logo_alt",
      "label": "Logo alt text",
      "default": "Eagle & Ash"
    },
    {
      "type": "text",
      "id": "brand_text",
      "label": "Fallback brand text",
      "default": "EAGLE & ASH"
    },
    {
      "type": "header",
      "content": "Menus"
    },
    {
      "type": "link_list",
      "id": "primary_menu",
      "label": "Primary menu",
      "default": "footer"
    },
    {
      "type": "text",
      "id": "primary_menu_label",
      "label": "Primary menu aria label",
      "default": "Footer links column one"
    },
    {
      "type": "link_list",
      "id": "secondary_menu",
      "label": "Secondary menu"
    },
    {
      "type": "text",
      "id": "secondary_menu_label",
      "label": "Secondary menu aria label",
      "default": "Footer links column two"
    },
    {
      "type": "header",
      "content": "Bottom row"
    },
    {
      "type": "text",
      "id": "meta_part_one",
      "label": "Metadata part one",
      "default": "EAGLE & ASH"
    },
    {
      "type": "text",
      "id": "meta_part_two",
      "label": "Metadata part two",
      "default": "Veritohne OÜ"
    },
    {
      "type": "text",
      "id": "meta_part_three",
      "label": "Metadata part three",
      "default": "Betooni tn 14a, 13816, Tallinn, Estonia"
    },
    {
      "type": "text",
      "id": "bottom_meta_label",
      "label": "Metadata aria label",
      "default": "Company metadata"
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "Contact email",
      "default": "hello@eagleandash.com"
    },
    {
      "type": "text",
      "id": "social_label",
      "label": "Social links aria label",
      "default": "Social media links"
    }
  ],
  "blocks": [
    {
      "type": "social_link",
      "name": "t:names.social_link",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "t:settings.title",
          "default": "Instagram",
          "info": "t:info.password_footer_social_title"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:settings.link"
        },
        {
          "type": "image_picker",
          "id": "custom_icon",
          "label": "t:settings.image_icon",
          "info": "t:info.password_footer_social_custom_icon"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom footer",
      "category": "t:categories.footer",
      "settings": {
        "newsletter_heading": "Be the first to discover new collections.",
        "primary_menu": "footer",
        "contact_email": "hello@eagleandash.com"
      },
      "blocks": [
        {
          "type": "social_link",
          "settings": {
            "title": "Instagram",
            "link": "https://www.instagram.com/eagleandash/"
          }
        },
        {
          "type": "social_link",
          "settings": {
            "title": "Facebook",
            "link": "https://www.facebook.com/people/eagleandash/61590270338294/"
          }
        },
        {
          "type": "social_link",
          "settings": {
            "title": "Amazon",
            "link": "https://www.amazon.com/stores/page/54F7FEDD-529C-4894-8E55-8D4A601F3CC1"
          }
        }
      ]
    }
  ]
}
{% endschema %}
