{% liquid
  assign primary_menu = section.settings.primary_menu
  if primary_menu == blank and linklists['footer'] != blank
    assign primary_menu = linklists['footer']
  endif

  assign secondary_menu = section.settings.secondary_menu
  if secondary_menu == blank and linklists['footer-menu-block-two'] != blank
    assign secondary_menu = linklists['footer-menu-block-two']
  endif

  assign footer_logo = section.settings.logo_image
  if footer_logo == blank and settings.logo != blank
    assign footer_logo = settings.logo
  endif
%}

<div class="custom-footer-divider" aria-hidden="true" role="presentation"></div>
<div
  class="custom-footer"
>
  <div class="custom-footer__main">
    <div class="custom-footer__newsletter">
      {% if section.settings.newsletter_heading != blank %}
        <h2 class="custom-footer__newsletter-heading">{{ section.settings.newsletter_heading }}</h2>
      {% endif %}

      <div class="custom-footer__newsletter-form">
        {%- liquid
          assign klaviyo_submit_label = section.settings.klaviyo_submit_label
          if klaviyo_submit_label == blank
            assign klaviyo_submit_label = 'SEND'
          endif
        -%}
        {% render 'email-signup-klaviyo-form',
          klaviyo_company_id: section.settings.klaviyo_company_id,
          klaviyo_list_id: section.settings.klaviyo_list_id,
          label: klaviyo_submit_label,
          custom_source: 'Eagle & Ash footer',
          form_id: section.id
        %}
      </div>
    </div>

    <div class="custom-footer__brand">
      {% if footer_logo != blank %}
        <img
          class="custom-footer__logo-image"
          src="{{ footer_logo | image_url: width: 500 }}"
          width="{{ footer_logo.width }}"
          height="{{ footer_logo.height }}"
          alt="{{ footer_logo.alt | default: section.settings.logo_alt | default: shop.name | escape }}"
          loading="lazy"
        >
      {% endif %}

      <div class="custom-footer__meta" aria-label="{{ section.settings.bottom_meta_label | escape }}">
        {% if section.settings.meta_part_one != blank %}
          <span class="custom-footer__meta-brand">{{ section.settings.meta_part_one }}</span>
        {% endif %}
        {% if section.settings.meta_part_two != blank %}
          <span>{{ section.settings.meta_part_two }}</span>
        {% endif %}
        {% if section.settings.meta_part_three != blank %}
          <span>{{ section.settings.meta_part_three }}</span>
        {% endif %}
      </div>
      
    </div> 

    <div class="custom-footer__menus">
      <nav class="custom-footer__menu-column" aria-label="{{ section.settings.primary_menu_label | escape }}">
        {% if primary_menu != blank %}
          <ul class="custom-footer__menu-list" role="list">
            {% for link in primary_menu.links %}
              <li class="custom-footer__menu-item">
                <a href="{{ link.url }}" class="custom-footer__menu-link">
                  {{- link.title -}}
                </a>
              </li>
            {% endfor %}
          </ul>
        {% endif %}
      </nav>

      <nav class="custom-footer__menu-column" aria-label="{{ section.settings.secondary_menu_label | escape }}">
        {% if secondary_menu != blank %}
          <ul class="custom-footer__menu-list" role="list">
            {% for link in secondary_menu.links %}
              <li class="custom-footer__menu-item">
                <a href="{{ link.url }}" class="custom-footer__menu-link">
                  {{- link.title -}}
                </a>
              </li>
            {% endfor %}
          </ul>
        {% endif %}
      </nav>
    </div>
  </div>

  <div class="custom-footer__bottom">
    {% if section.settings.contact_email != blank %}
      <a class="custom-footer__email" href="mailto:{{ section.settings.contact_email | strip | escape }}">
        {{- section.settings.contact_email | escape -}}
      </a>
    {% endif %}

    <ul class="custom-footer__social" role="list" aria-label="{{ section.settings.social_label | escape }}">
      {% for block in section.blocks %}
        {% if block.type == 'social_link' %}
          {% render 'password-footer-social-item',
            title: block.settings.title,
            link: block.settings.link,
            image_upload: block.settings.custom_icon,
            shopify_attributes: block.shopify_attributes,
            modifier_class: 'custom-footer__social-item'
          %}
        {% endif %}
      {% endfor %}
    </ul>
  </div>
</div>

{% stylesheet %}
  .custom-footer-divider {
    height: 56px;
    background-color: var(--deepest-brand-blue);
  }

  .custom-footer,
  .custom-footer__main,
  .custom-footer__bottom {
    background-color: #ffffff;
  }

  .custom-footer {
    max-width: 1920px;
    margin-inline: auto;
    padding-top: 35px;
    padding-bottom: 10px;
    padding-inline: 40px;
  }

  .custom-footer__newsletter-form {
    margin-block-start: 30px;

    & .email-signup-klaviyo__form-wrap {
      position: relative;
      gap: 0;
    }

    & .email-signup__fields {
      position: relative;
    }

    & .email-signup-klaviyo__form .email-signup-klaviyo__input {
      min-height: 26px;
      padding: 0;
      padding-right: 80px;
      font-size: 16px;
      color: var(--ash-amber-orange);
      border: none;
      border-bottom: 1px solid var(--ash-amber-orange) !important;

      &::placeholder {
        color: var(--ash-amber-orange);
      }
    }

    & .email-signup-klaviyo__button {
      position: absolute;
      right: 0;
      top: 0;
      min-height: 26px;
      padding: 0;
      font-size: 16px;
      background-color: transparent;
      border-bottom: 1px solid var(--ash-amber-orange);
      transition: color .3s ease;

      &:hover {
        background-color: transparent;
        color: var(--deepest-brand-blue);
      }
    }

    & .email-signup-klaviyo__interest-options {
      margin-block-start: 10px;
    }

    & .email-signup-klaviyo__interest-option input {
      width: 8px;
      height: 8px;
      border-color: var(--ash-amber-orange);
      border-width: 1px;
    }

    & .email-signup-klaviyo__interest-option label {
      font-size: 14px;
      line-height: 1.35;
      color: #000;
    }

    & .email-signup-klaviyo__interest-option:hover input {
      border-color: var(--ash-amber-orange);
    }

    & .email-signup-klaviyo__interest-option input::after {
      width: 8px;
      height: 8px;
      background-color: var(--ash-amber-orange);
    }

    & .email-signup-klaviyo__interest-option input:checked::after {
      background-color: var(--ash-amber-orange);
    }

    & .email-signup-klaviyo__interest-options {
      font-size: 12px;
      color: var(--ash-amber-orange);
    }
    
    & .email-signup-klaviyo__interest-option > span {
      opacity: 1;
    }

    & label:has(input[type=radio]) {
      gap: 5px; 
    }
  }

  .custom-footer__main {
    display: grid;
    grid-template-columns: 325px 1fr 325px;  
    align-items: start;
    column-gap: 36px;
  }

  .custom-footer__newsletter-heading {
    margin: 0;
    font-family: 'Lora', serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 20px;
    color: var(--ash-amber-orange);
  }

  .custom-footer__brand {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: center;  
    gap: 20px;
    min-height: 100%;
    margin-block-start: -6px;
  }

  .custom-footer__logo-image {
    display: block;
    width: 100%;
    height: auto;
    max-width: 160px;
  }

  .custom-footer__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
    font-family: 'Lora', serif;
    font-size: 12px;
    font-weight: 400;
    color: var(--ash-amber-orange); 
  }

  .custom-footer__meta-brand {
    font-weight: 600;
    text-transform: uppercase; 
  } 

  .custom-footer__menus {
    display: grid;
    grid-template-columns: repeat(2, minmax(125px, 1fr));
    gap: 6px 24px;
  }

  .custom-footer__menu-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .custom-footer__menu-item {
    margin: 0;
  }

  .custom-footer__menu-link {
    color: var(--ash-amber-orange);
    font-family: 'Lora', serif;
    font-size: 12px;
    font-weight: 400;
    text-decoration: none;
    transition: color .3s ease;
  }

  .custom-footer__menu-link:hover {
    color: var(--deepest-brand-blue);
  }

  .custom-footer__bottom {
    margin-top: 12px;
    padding-top: 8px;
    border-top: 1px solid #1f2937;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto auto;
    align-items: center;
    column-gap: 24px;
    row-gap: 8px;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Custom footer",
  "class": "section-wrapper custom-footer-section",
  "tag": "footer",
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Newsletter content"
